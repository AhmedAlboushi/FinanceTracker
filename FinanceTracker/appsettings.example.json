{
  "ConnectionStrings": {
    "FinanceTrackerLocalDb": "your-connection-string-here"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "Finance Tracker",
    "SenderEmail": "your-email-here",
    "Password": "your-gmail-app-password-here"
  },
  "FrontendUrl": "http://localhost:5173",
  "JwtSettings": {
    "Issuer": "FinanceTracker",
    "Audience": "FinanceTrackerUsers",
    "ExpirationMinutes": "30"
  },
  "JWT_SECRET_KEY": "your-secret-key-here",
  "Cloudinary": {
    "CloudName": "your-cloud-name-here",
    "ApiKey": "your-api-key-here",
    "ApiSecret": "your-api-secret-here"
  }
}
